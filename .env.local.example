# --- Database (required) ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- LLM provider (set ONE of these) ---

# Option A: Google Gemini (free tier, recommended)
# Get a key at https://aistudio.google.com
# GOOGLE_GENERATIVE_AI_API_KEY=...
# LLM_MODEL=gemini-flash-latest    # default if unset

# Option B: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5       # default if unset

# Option C: OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini            # default if unset
